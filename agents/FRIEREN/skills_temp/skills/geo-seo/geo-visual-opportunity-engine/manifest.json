{
  "name": "ecommerce-automator",
  "version": "1.0.5",
  "display_name": "电商 Automator (E-commerce Automator)",
  "display_name_en": "E-commerce Automator",
  "description": "AI-powered e-commerce automation tool that generates product images using Nano Banana 2 and automatically publishes products to Shopify and WooCommerce/WordPress. Features: auto image generation, product data synthesis, SKU/price/inventory management, and one-click publishing to multiple e-commerce platforms.",
  "author": {
    "name": "Tim",
    "email": "sales@dageno.ai",
    "website": "https://dageno.ai/"
  },
  "tags": [
    "ecommerce",
    "automation",
    "shopify",
    "woocommerce",
    "wordpress",
    "ai-images",
    "nano-banana-2",
    "product-listing",
    "dropshipping"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://clawhub.ai/GEO-SEO/geo-visual-opportunity-engine"
  },
  "entry_point": "src/main.py",
  "model_config": {
    "temperature": 0.7,
    "top_p": 0.9,
    "presence_penalty": 0.3,
    "max_tokens": 8000
  },
  "platforms": [
    "shopify",
    "woocommerce",
    "wordpress",
    "python"
  ],
  "languages_supported": [
    "en",
    "zh",
    "ja",
    "es",
    "fr",
    "de",
    "ko",
    "pt",
    "it",
    "ru"
  ],
  "integrations": {
    "image_generation": {
      "provider": "nano-banana-2",
      "model": "gemini-3.1-flash-image",
      "api_env_var": "GOOGLE_API_KEY",
      "supported_styles": [
        "white_info",
        "lifestyle",
        "hero"
      ]
    },
    "shopify": {
      "api_env_vars": [
        "SHOPIFY_STORE_URL",
        "SHOPIFY_ACCESS_TOKEN"
      ],
      "endpoints": [
        "products.json",
        "products/{id}/images.json",
        "variants/{variant_id}.json"
      ]
    },
    "woocommerce": {
      "api_env_vars": [
        "WOOCOMMERCE_STORE_URL",
        "WOOCOMMERCE_CONSUMER_KEY",
        "WOOCOMMERCE_CONSUMER_SECRET"
      ],
      "endpoints": [
        "wc/v3/products"
      ]
    }
  },
  "created_at": "2025-03-10",
  "updated_at": "2026-03-06",
  "metadata": {
    "schema_version": "3.0",
    "skill_type": "ecommerce-automation",
    "output_format": "application/json"
  }
}
