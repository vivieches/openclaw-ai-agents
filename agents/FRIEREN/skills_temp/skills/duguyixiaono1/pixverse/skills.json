{
  "skills": [
    {
      "name": "gen-video",
      "command": "node dist/gen-video.js",
      "description": "Generate video from text prompt",
      "parameters": [
        {
          "name": "prompt",
          "description": "Text description of the video to generate",
          "required": true
        },
        {
          "name": "aspect_ratio",
          "description": "Video aspect ratio (16:9, 9:16, 1:1, 4:3, 3:4)",
          "required": false,
          "default": "16:9"
        },
        {
          "name": "duration",
          "description": "Video duration in seconds (5 or 8)",
          "required": false,
          "default": "5"
        },
        {
          "name": "resolution",
          "description": "Video resolution (360p, 540p, 720p, 1080p)",
          "required": false,
          "default": "720p"
        },
        {
          "name": "model",
          "description": "AI model version (v4.5 or v5)",
          "required": false,
          "default": "v4.5"
        },
        {
          "name": "motion_mode",
          "description": "Motion speed (normal or fast)",
          "required": false,
          "default": "normal"
        },
        {
          "name": "negative_prompt",
          "description": "Elements to exclude from the video",
          "required": false
        }
      ]
    },
