  "description": "Transform your local OpenClaw agents into a remote-controlled team. iOS/Android apps, web dashboard, multi-agent chat, real-time cost monitoring.",
  "dependencies": {
    "node-fetch": "^3.3.2",
    "ws": "^8.14.2",
    "@ekybot/connector": "^1.0.0"
  },
