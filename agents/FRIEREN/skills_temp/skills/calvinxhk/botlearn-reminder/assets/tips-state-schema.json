{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "botlearn-tips-state",
  "title": "BotLearn Tips State",
  "description": "Tracks the 7-day BotLearn quickstart tutorial reminder progress",
  "type": "object",
  "required": ["version", "installDate"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "example": "0.1.0"
    },
    "installDate": {
      "type": "string",
      "format": "date",
      "description": "Date when the skill was first activated (YYYY-MM-DD). Used to calculate journey day.",
      "example": "2026-03-03"
    },
    "lastReminderDate": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date of the most recent reminder sent (YYYY-MM-DD). Null if no reminder sent yet.",
      "example": "2026-03-04"
    },
    "lastReminderDay": {
      "type": "integer",
      "minimum": 0,
      "maximum": 7,
      "description": "Journey day of the last reminder. 0 if none sent.",
      "example": 1
    },
    "reminders": {
      "type": "array",
      "description": "History of all reminders sent during the 7-day journey",
      "items": {
        "type": "object",
        "required": ["day", "date", "sentAt"],
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 7,
            "description": "Journey day (1-7)"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Calendar date when reminder was sent"
          },
          "urls": {
            "type": "array",
            "items": { "type": "string", "format": "uri" },
            "description": "URLs that were included in this reminder"
          },
          "sentAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the reminder was sent"
          }
        }
      }
    }
  },
  "examples": [
    {
      "version": "0.1.0",
      "installDate": "2026-03-03",
      "lastReminderDate": "2026-03-04",
      "lastReminderDay": 2,
      "reminders": [
        {
          "day": 1,
          "date": "2026-03-03",
          "urls": [
            "https://botlearn.ai/en/quickstart/step1",
            "https://botlearn.ai/en/quickstart/step2"
          ],
          "sentAt": "2026-03-03T09:00:00Z"
        },
        {
          "day": 2,
          "date": "2026-03-04",
          "urls": [
            "https://botlearn.ai/en/quickstart/step3"
          ],
          "sentAt": "2026-03-04T09:00:00Z"
        }
      ]
    }
  ]
}
